# Autonomyx Fast SaaS Toolkit — Environment Variables
# Copy to .env and fill in values. Secrets are auto-generated by `fast-saas init`.

# ── Global ────────────────────────────────────
DOMAIN=example.com
ADMIN_EMAIL=admin@example.com
COMPOSE_PROFILES=essential,core,ops

# ── PostgreSQL ────────────────────────────────
POSTGRES_USER=saas
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=saas
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME
REDIS_PORT=6379

# ── Logto (Auth) ──────────────────────────────
LOGTO_PORT=3301
LOGTO_ADMIN_PORT=3302

# ── Lago (Billing) ───────────────────────────
LAGO_SECRET_KEY=CHANGE_ME
LAGO_RSA_PRIVATE_KEY=CHANGE_ME
LAGO_ENCRYPTION_PRIMARY_KEY=CHANGE_ME
LAGO_ENCRYPTION_DETERMINISTIC_KEY=CHANGE_ME
LAGO_ENCRYPTION_KEY_SALT=CHANGE_ME

# ── RustFS (S3 Storage) ──────────────────────
RUSTFS_ACCESS_KEY=CHANGE_ME
RUSTFS_SECRET_KEY=CHANGE_ME
RUSTFS_API_PORT=9000
RUSTFS_CONSOLE_PORT=9001

# ── GlitchTip (Error Tracking) ───────────────
GLITCHTIP_SECRET_KEY=CHANGE_ME

# ── Grafana (Monitoring) ─────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ── Matomo (Analytics) ───────────────────────
MATOMO_DB_PASSWORD=CHANGE_ME
MATOMO_DB_ROOT_PASSWORD=CHANGE_ME

# ── Mautic (Email Marketing) ─────────────────
MAUTIC_ADMIN_PASSWORD=CHANGE_ME

# ── SMTP (for services that send email) ──────
SMTP_USER=noreply
SMTP_PASSWORD=CHANGE_ME

# ── NocoDB (Admin Dashboard) ─────────────────
NOCODB_JWT_SECRET=CHANGE_ME

# ── n8n (Workflow Automation) ─────────────────
N8N_ENCRYPTION_KEY=CHANGE_ME

# ── Docmost (Documentation) ──────────────────
DOCMOST_SECRET=CHANGE_ME

# ── SaaS API ─────────────────────────────────
API_PORT=4000
LOGTO_AUDIENCE=
PLATFORM_API_KEY=CHANGE_ME
