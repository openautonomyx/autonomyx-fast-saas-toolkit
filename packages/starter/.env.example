# Autonomyx Fast SaaS Toolkit — Environment Variables
# Copy to .env and fill in values. Secrets are auto-generated by `fast-saas init`.

# ── Global ────────────────────────────────────
DOMAIN=example.com
ADMIN_EMAIL=admin@example.com
COMPOSE_PROFILES=essential,core,ops

# ── PostgreSQL ────────────────────────────────
POSTGRES_USER=saas
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=saas
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME
REDIS_PORT=6379

# ── Logto (Auth) ──────────────────────────────
LOGTO_PORT=3301
LOGTO_ADMIN_PORT=3302
# Admin credentials for Logto's Management API.
# Used by dashboard-init bootstrap to register the OIDC client on first boot.
LOGTO_ADMIN_USER=admin
LOGTO_ADMIN_PASSWORD=CHANGE_ME
# OIDC client credentials for the dashboard.
# Leave empty — dashboard-init populates these on first boot via the
# Management API. If you set them manually, the bootstrap is a no-op.
LOGTO_APP_ID=
LOGTO_APP_SECRET=
# 32+ byte hex string used to encrypt dashboard session cookies.
# Generate with: openssl rand -hex 32
LOGTO_COOKIE_SECRET=CHANGE_ME

# ── Lago (Billing) ───────────────────────────
LAGO_SECRET_KEY=CHANGE_ME
LAGO_RSA_PRIVATE_KEY=CHANGE_ME
LAGO_ENCRYPTION_PRIMARY_KEY=CHANGE_ME
LAGO_ENCRYPTION_DETERMINISTIC_KEY=CHANGE_ME
LAGO_ENCRYPTION_KEY_SALT=CHANGE_ME

# ── RustFS (S3 Storage) ──────────────────────
RUSTFS_ACCESS_KEY=CHANGE_ME
RUSTFS_SECRET_KEY=CHANGE_ME
RUSTFS_API_PORT=9000
RUSTFS_CONSOLE_PORT=9001

# ── GlitchTip (Error Tracking) ───────────────
GLITCHTIP_SECRET_KEY=CHANGE_ME

# ── Grafana (Monitoring) ─────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ── Matomo (Analytics) ───────────────────────
MATOMO_DB_PASSWORD=CHANGE_ME
MATOMO_DB_ROOT_PASSWORD=CHANGE_ME

# ── Mautic (Email Marketing) ─────────────────
MAUTIC_ADMIN_PASSWORD=CHANGE_ME

# ── SMTP (for all services that send email) ──
# Default: Stalwart (internal). Change to any provider:
#   SendGrid:  SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_USER=apikey  SMTP_PASSWORD=SG.xxx
#   Mailgun:   SMTP_HOST=smtp.mailgun.org   SMTP_PORT=587  SMTP_USER=postmaster@mg.domain
#   AWS SES:   SMTP_HOST=email-smtp.us-east-1.amazonaws.com  SMTP_PORT=587
#   Gmail:     SMTP_HOST=smtp.gmail.com     SMTP_PORT=587  (use app password)
SMTP_HOST=stalwart
SMTP_PORT=25
SMTP_USER=noreply
SMTP_PASSWORD=CHANGE_ME
APP_NAME=SaaS Platform

# ── NocoDB (Admin Dashboard) ─────────────────
NOCODB_JWT_SECRET=CHANGE_ME

# ── n8n (Workflow Automation) ─────────────────
N8N_ENCRYPTION_KEY=CHANGE_ME

# ── Docmost (Documentation) ──────────────────
DOCMOST_SECRET=CHANGE_ME

# ── SaaS API ─────────────────────────────────
API_PORT=4000
LOGTO_AUDIENCE=
PLATFORM_API_KEY=CHANGE_ME

# ── LibreChat (AI Chat) ──────────────────────
LIBRECHAT_CREDS_KEY=CHANGE_ME
LIBRECHAT_CREDS_IV=CHANGE_ME
LIBRECHAT_JWT_SECRET=CHANGE_ME
LIBRECHAT_JWT_REFRESH_SECRET=CHANGE_ME
LIBRECHAT_MONGODB_PASSWORD=CHANGE_ME
MEILI_MASTER_KEY=CHANGE_ME

# ── Langflow (AI Workflows) ─────────────────
LANGFLOW_SECRET_KEY=CHANGE_ME
LANGFLOW_AUTO_LOGIN=true
LANGFLOW_SUPERUSER=admin
LANGFLOW_SUPERUSER_PASSWORD=CHANGE_ME

# ── Langfuse (LLM Observability) ─────────────
LANGFUSE_SECRET_KEY=CHANGE_ME
LANGFUSE_SALT=CHANGE_ME
LANGFUSE_TELEMETRY_ENABLED=false

# ── Ollama (Local LLMs) ─────────────────────
# No secrets needed — models stored in volume

# ── Claude Agent (Agent Runner) ──────────────
ANTHROPIC_API_KEY=CHANGE_ME
CLAUDE_AGENT_API_KEY=CHANGE_ME
CLAUDE_AGENT_PORT=3100
