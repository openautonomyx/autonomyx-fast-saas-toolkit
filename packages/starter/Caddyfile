# Autonomyx Fast SaaS Toolkit — Caddy Reverse Proxy
# All subdomains get automatic HTTPS via ACME
# Replace {$DOMAIN} with your domain or set it in .env

# ── Core ──────────────────────────────────────

auth.{$DOMAIN} {
	reverse_proxy logto:3001
}

auth-admin.{$DOMAIN} {
	reverse_proxy logto:3002
}

billing.{$DOMAIN} {
	reverse_proxy lago-front:80
}

billing-api.{$DOMAIN} {
	reverse_proxy lago-api:3000
}

storage.{$DOMAIN} {
	reverse_proxy rustfs:9000
}

storage-console.{$DOMAIN} {
	reverse_proxy rustfs:9001
}

api.{$DOMAIN} {
	reverse_proxy saas-api:4000
}

# The command center — primary user-facing front door.
# All admin operations (tenants, users, billing, workflows, AI, monitoring)
# happen here. Logto authenticates; the dashboard forwards session tokens
# to the API. Other subdomains (auth.*, billing.*, etc.) are the headless
# backends and should rarely be touched directly by end users.
app.{$DOMAIN} {
	reverse_proxy dashboard:3200
}

# ── Ops ───────────────────────────────────────

monitor.{$DOMAIN} {
	reverse_proxy grafana:3000
}

errors.{$DOMAIN} {
	reverse_proxy glitchtip:8000
}

status.{$DOMAIN} {
	reverse_proxy uptime-kuma:3001
}

# ── Growth ────────────────────────────────────

analytics.{$DOMAIN} {
	reverse_proxy matomo:80
}

email.{$DOMAIN} {
	reverse_proxy mautic:80
}

admin.{$DOMAIN} {
	reverse_proxy nocodb:8080
}

auto.{$DOMAIN} {
	reverse_proxy n8n:5678
}

tools.{$DOMAIN} {
	reverse_proxy appsmith:80
}

docs.{$DOMAIN} {
	reverse_proxy docmost:3000
}

# ── AI ────────────────────────────────────────

chat.{$DOMAIN} {
	reverse_proxy librechat:3080
}

flow.{$DOMAIN} {
	reverse_proxy langflow:7860
}

models.{$DOMAIN} {
	reverse_proxy ollama:11434
}

agent.{$DOMAIN} {
	reverse_proxy claude-agent:3100
}

observe.{$DOMAIN} {
	reverse_proxy langfuse:3000
}

# ── Your Application ─────────────────────────
# The dashboard at app.{$DOMAIN} (declared above) is the primary front door.
# Add custom application subdomains here — e.g. if you build a storefront
# that lives at shop.{$DOMAIN} pointed at a storefront container:
#
# shop.{$DOMAIN} {
# 	reverse_proxy storefront:3000
# }
